# Web app (apps/web) — Next.js + same-origin protected API.

# URL of the public overlay Worker (apps/server). Local `alchemy dev` wires this
# automatically; set it for a bare `next dev`.
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Cloudflare Access (gates /control + /api/trpc). Leave blank locally and set
# ACCESS_DISABLED=true to bypass; NEVER disable in production.
CF_ACCESS_TEAM_DOMAIN=
CF_ACCESS_AUD=
ACCESS_DISABLED=true
