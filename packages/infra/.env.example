# Deploy (packages/infra, Alchemy → Cloudflare). Run `bun run deploy`.

# Encrypts Alchemy's local state. Pick a strong value and keep it stable.
ALCHEMY_PASSWORD=

# Cloudflare credentials for the deploy.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# Production hosts / CORS. Defaults to https://howlwheel.mrdemonwolf.workers.dev.
WEB_URL=
CORS_ORIGIN=

# Cloudflare Access application (gates /control + /api/trpc on the web Worker).
CF_ACCESS_TEAM_DOMAIN=yourteam.cloudflareaccess.com
CF_ACCESS_AUD=
